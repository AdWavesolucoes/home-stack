# =============================================================
# Variáveis de ambiente — copiar para .env e preencher
# NUNCA commitar o arquivo .env
# =============================================================

# --- Geral ---
TZ=America/Sao_Paulo
PUID=1000
PGID=1000

# Diretório base de dados no host
DATA_DIR=/opt/homelab

# --- PostgreSQL ---
POSTGRES_USER=homelab
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_DB=homelab

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=TROQUE_ESTA_SENHA
GF_SERVER_DOMAIN=grafana.home

# --- Navidrome ---
ND_MUSICFOLDER=/opt/homelab/navidrome/music
ND_DATAFOLDER=/opt/homelab/navidrome/data
ND_BASEURL=
ND_LOGLEVEL=info
ND_SESSIONTIMEOUT=24h

# --- Plex ---
PLEX_CLAIM=claim-XXXXXXXXXXXXXXXXX
# Obter em: https://www.plex.tv/claim/

# --- qBittorrent ---
WEBUI_PORT=8090

# --- Minecraft ---
EULA=TRUE
MC_TYPE=PAPER
MC_VERSION=LATEST
MC_MEMORY=2G
MC_SERVER_NAME=Meu Servidor Minecraft

# --- Watchtower ---
# Intervalo de verificação em segundos (86400 = 1 dia)
WATCHTOWER_SCHEDULE=0 0 4 * * *
WATCHTOWER_CLEANUP=true
WATCHTOWER_NOTIFICATION_URL=
# Notificações via Shoutrrr: https://containrrr.dev/shoutrrr/
# Exemplo Telegram: telegram://TOKEN@telegram?chats=CHAT_ID

# --- Kiwix ---
KIWIX_DATA_DIR=/opt/homelab/kiwix

# --- Homepage ---
HOMEPAGE_VAR_PIHOLE_KEY=SUA_API_KEY_PIHOLE
HOMEPAGE_VAR_PORTAINER_KEY=SUA_API_KEY_PORTAINER
